# ==============================
# VELOX SOLUTIONS — ENVIRONMENT
# ==============================

# ── GEMINI AI ──────────────────────────────────────────────────────────────
# Required for Gemini AI API calls. Set this in your Railway dashboard.
GEMINI_API_KEY=your_gemini_api_key_here

# ── BACKEND ────────────────────────────────────────────────────────────────
# The URL of the allowed frontend origin for CORS (Railway backend).
# Set this to your Vercel frontend URL in production.
# Leave unset to allow all origins (not recommended for production).
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ── DISCORD WEBHOOK ────────────────────────────────────────────────────────
# Webhook URL for dispatching contact form submissions to a Discord channel.
# Leave empty to disable Discord notifications.
DISCORD_WEBHOOK_URL=

# ── FRONTEND (Vite) ────────────────────────────────────────────────────────
# The base URL of the backend API. Only needed when frontend and backend
# are deployed separately (e.g., Vercel + Railway).
# In local development, leave this EMPTY — Vite dev server proxies via the same port.
# In Vercel production, set this to your Railway backend URL:
# Example: https://your-app.up.railway.app
VITE_API_URL=
